<section class="p-4 bg-zinc-50 dark:bg-black min-h-screen flex items-center justify-center">
  <div class="grid grid-cols-1 gap-4 lg:grid-cols-4 lg:grid-rows-3 lg:h-[90vh] max-w-7xl mx-auto w-full">
    
    <!-- 1. Bienvenido (C1, R1-2) -->
    <div class="lg:col-span-1 lg:row-span-2 ring-1 dark:ring-white/10 ring-primary/5 bg-white dark:bg-secondary shadow-xl rounded-3xl p-8 flex flex-col justify-center">
      <div class="flex items-center gap-x-4">
        <div class="h-12 w-12 rounded-full bg-indigo-500 flex items-center justify-center text-white font-bold shadow-md">AB</div>
        <div class="text-sm">
          <p class="font-bold dark:text-white text-primary">Antonio Barrón</p>
          <p class="text-zinc-500 dark:text-zinc-400">Full Stack Developer</p>
        </div>
      </div>
      <h1 class="text-3xl mt-6 font-bold lg:text-4xl tracking-tighter dark:text-white text-primary">¡Bienvenido!</h1>
      <p class="mt-4 text-sm text-zinc-500 dark:text-zinc-400 font-light leading-relaxed">
        Desarrollador enfocado en Frontend, especializado en React y código limpio.
      </p>
    </div>

    <!-- 2. Proyectos Destacados (C2-3, R1) -->
    <div class="lg:col-span-2 lg:row-span-1 ring-1 dark:ring-white/10 ring-primary/5 rounded-3xl p-8 bg-white dark:bg-secondary shadow-xl flex flex-col justify-between">
      <div class="flex items-center justify-between mb-2">
        <p class="text-xl font-bold dark:text-white text-primary leading-tight font-serif italic">Proyectos destacados</p>
        <a href="https://github.com/barockatr?tab=repositories" target="_blank" class="text-xs text-blue-500 hover:text-blue-600 transition-colors">Ver todos →</a>
      </div>
      <div class="grid grid-cols-1 sm:grid-cols-3 gap-3">
        <!-- Rick & Morty App -->
        <a href="https://rick-morty-character-hy17s2mni.vercel.app" target="_blank" class="rounded-xl overflow-hidden bg-zinc-50 dark:bg-tertiary ring-1 ring-primary/5 dark:ring-white/5 hover:scale-[1.02] transition-transform duration-300 group">
           <img src="/images/rick-morty.png" alt="Rick & Morty" class="w-full aspect-video object-cover opacity-90 group-hover:opacity-100" />
           <div class="p-2">
             <p class="text-[10px] font-bold dark:text-white text-primary group-hover:text-blue-500 transition-colors">Rick & Morty</p>
             <p class="text-[9px] text-zinc-500 dark:text-zinc-400">React / API</p>
           </div>
        </a>
        <!-- TCG Arena Pokédex -->
        <a href="https://tcg-arena-pokedex.vercel.app" target="_blank" class="rounded-xl overflow-hidden bg-zinc-50 dark:bg-tertiary ring-1 ring-primary/5 dark:ring-white/5 hover:scale-[1.02] transition-transform duration-300 group">
          <img src="/images/pokedex.png" alt="Pokédex" class="w-full aspect-video object-cover opacity-90 group-hover:opacity-100" />
          <div class="p-2">
            <p class="text-[10px] font-bold dark:text-white text-primary group-hover:text-blue-500 transition-colors">TCG Pokédex</p>
            <p class="text-[9px] text-zinc-500 dark:text-zinc-400">React / API</p>
          </div>
       </a>
       <!-- Ciudad Digital -->
       <a href="https://ciudadno-gobierno-digital.vercel.app" target="_blank" class="rounded-xl overflow-hidden bg-zinc-50 dark:bg-tertiary ring-1 ring-primary/5 dark:ring-white/5 hover:scale-[1.02] transition-transform duration-300 group">
        <img src="/images/gobierno.png" alt="Ciudad & Gobierno" class="w-full aspect-video object-cover opacity-90 group-hover:opacity-100" />
        <div class="p-2">
          <p class="text-[10px] font-bold dark:text-white text-primary group-hover:text-blue-500 transition-colors">Ciudad Digital</p>
          <p class="text-[9px] text-zinc-500 dark:text-zinc-400">Digital Services</p>
        </div>
     </a>
      </div>
    </div>

    <!-- 3. Conéctate (C4, R1) -->
    <div class="lg:col-span-1 lg:row-span-1 ring-1 dark:ring-white/10 ring-primary/5 rounded-3xl p-6 bg-white dark:bg-secondary shadow-xl flex flex-col justify-between">
      <p class="text-lg font-bold dark:text-white text-primary">Conéctate</p>
      <div class="flex gap-4 flex-wrap items-center justify-center mt-2">
        <!-- Social Icons remain the same -->
        <a href="mailto:antonioatristain06@gmail.com" class="text-primary dark:text-white hover:scale-110 transition-transform"><svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" fill="none"><path stroke="none" d="M0 0h24v24H0z" fill="none"/><path d="M3 7a2 2 0 0 1 2 -2h14a2 2 0 0 1 2 2v10a2 2 0 0 1 -2 2h-14a2 2 0 0 1 -2 -2v-10z"/><path d="M3 7l9 6l9 -6"/></svg></a>
        <a href="https://github.com/barockatr" target="_blank" class="text-primary dark:text-white hover:scale-110 transition-transform"><svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" fill="none"><path d="M9 19c-4.3 1.4 -4.3 -2.5 -6 -3m12 5v-3.5c0 -1 .1 -1.4 -.5 -2c2.8 -.3 5.5 -1.4 5.5 -6a4.6 4.6 0 0 0 -1.3 -3.2a4.2 4.2 0 0 0 -.1 -3.2s-1.1 -.3 -3.5 1.3a12.3 12.3 0 0 0 -6.2 0c-2.4 -1.6 -3.5 -1.3 -3.5 -1.3a4.2 4.2 0 0 0 -.1 3.2a4.6 4.6 0 0 0 -1.3 3.2c0 4.6 2.7 5.7 5.5 6c-.6 .6 -.6 1.2 -.5 2v3.5" /></svg></a>
        <a href="https://www.linkedin.com/in/antonio-barr%C3%B3n-atristain-8b74b3283/" target="_blank" class="text-primary dark:text-white hover:scale-110 transition-transform"><svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" fill="none"><path d="M4 4m0 2a2 2 0 0 1 2 -2h12a2 2 0 0 1 2 2v12a2 2 0 0 1 -2 2h-12a2 2 0 0 1 -2 -2z" /><path d="M8 11l0 5" /><path d="M8 8l0 .01" /><path d="M12 16l0 -5" /><path d="M16 16v-3a2 2 0 0 0 -4 0" /></svg></a>
        <a href="https://wa.me/527223680858" target="_blank" class="text-primary dark:text-white hover:scale-110 transition-transform"><svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" fill="none"><path d="M3 21l1.65 -3.8a9 9 0 1 1 3.4 2.9l-5.05 .9"/><path d="M9 10a.5 .5 0 0 0 1 0v-1a.5 .5 0 0 0 -1 0v1a5 5 0 0 0 5 5h1a.5 .5 0 0 0 0 -1h-1a.5 .5 0 0 0 0 1"/></svg></a>
      </div>
    </div>

    <!-- 4. ¿Hablamos? (C2-3, R2) -->
    <div class="lg:col-span-2 lg:row-span-1 ring-1 dark:ring-white/10 ring-primary/5 rounded-3xl p-8 bg-white dark:bg-secondary shadow-xl flex items-center justify-between">
      <div class="text-left">
        <p class="text-xl font-bold dark:text-white text-primary">¿Hablamos?</p>
        <p class="text-xs text-zinc-500 dark:text-zinc-400">Hagamos realidad tu idea.</p>
      </div>
      <div class="flex gap-2">
        <input type="text" id="contact-name-quick" placeholder="Tu nombre" class="bg-zinc-100 dark:bg-tertiary p-2 rounded-lg text-xs outline-none border border-transparent focus:border-blue-500 dark:text-white">
        <button id="send-whatsapp-quick" class="bg-green-500 text-white px-6 py-2 rounded-lg text-xs font-bold hover:bg-green-600 transition-colors">WhatsApp</button>
      </div>
    </div>

    <!-- 5. Frase (C4, R2) -->
    <div class="lg:col-span-1 lg:row-span-1 ring-1 dark:ring-white/10 ring-primary/5 rounded-3xl p-6 bg-white dark:bg-secondary shadow-xl flex items-center justify-center text-center">
      <p class="text-[10px] italic text-zinc-500 dark:text-zinc-400 leading-tight">"El código es poesía en movimiento."</p>
    </div>

    <!-- 6. Tech Stack & Herramientas (C1-2, R3) -->
    <div class="lg:col-span-2 lg:row-span-1 ring-1 dark:ring-white/10 ring-primary/5 rounded-3xl p-6 bg-white dark:bg-secondary shadow-xl">
      <p class="text-sm font-bold dark:text-white text-primary mb-4 italic">Tech Stack & Herramientas</p>
      <div class="flex flex-wrap gap-2">
        <span class="inline-flex items-center gap-1.5 py-1.5 px-3 rounded-full text-[10px] font-medium bg-blue-500/10 text-blue-500 ring-1 ring-inset ring-blue-500/20">
          <img src="https://cdn.simpleicons.org/react/61DAFB" class="h-3 w-3" alt="React" /> React
        </span>
        <span class="inline-flex items-center gap-1.5 py-1.5 px-3 rounded-full text-[10px] font-medium bg-zinc-500/10 text-zinc-600 dark:text-zinc-300 ring-1 ring-inset ring-zinc-500/20 dark:ring-white/10">
          <img src="https://cdn.simpleicons.org/nextdotjs/white" class="h-3 w-3 dark:block hidden" />
          <img src="https://cdn.simpleicons.org/nextdotjs/black" class="h-3 w-3 dark:hidden block" /> Next.js
        </span>
        <span class="inline-flex items-center gap-1.5 py-1.5 px-3 rounded-full text-[10px] font-medium bg-blue-600/10 text-blue-400 ring-1 ring-inset ring-blue-600/20">
          <img src="https://cdn.simpleicons.org/typescript/3178C6" class="h-3 w-3" /> TS
        </span>
        <span class="inline-flex items-center gap-1.5 py-1.5 px-3 rounded-full text-[10px] font-medium bg-green-500/10 text-green-500 ring-1 ring-inset ring-green-500/20">
          <img src="https://cdn.simpleicons.org/nodedotjs/339933" class="h-3 w-3" /> Node.js
        </span>
        <span class="inline-flex items-center gap-1.5 py-1.5 px-3 rounded-full text-[10px] font-medium bg-sky-500/10 text-sky-400 ring-1 ring-inset ring-sky-500/20">
          <img src="https://cdn.simpleicons.org/tailwindcss/06B6D4" class="h-3 w-3" /> Tailwind
        </span>
      </div>
    </div>

    <!-- 7. Accede a mi trayectoria laboral completa (C3-4, R3) -->
    <div class="lg:col-span-2 lg:row-span-1 bg-zinc-100 dark:bg-white rounded-3xl p-6 flex items-center justify-between shadow-xl ring-1 ring-primary/5 dark:ring-white/10">
      <p class="text-black font-bold text-sm lg:text-base">Accede a mi trayectoria laboral completa</p>
      <a href="https://drive.google.com/file/d/18C_Rn6OQfgOqlbWGXwXzeK5FnKn0V6p0/view?usp=sharing" target="_blank" class="bg-black text-white px-6 py-3 rounded-full text-xs font-bold hover:bg-zinc-800 transition-colors uppercase tracking-wider">VER CV</a>
    </div>

  </div>

  <script>
    const whatsappBtn = document.getElementById('send-whatsapp-quick') as HTMLButtonElement | null;
    whatsappBtn?.addEventListener('click', () => {
      const name = (document.getElementById('contact-name-quick') as HTMLInputElement | null)?.value.trim();
      if (!name) { alert('Por favor escribe tu nombre.'); return; }
      const text = `Hola Antonio, soy ${name}. Te contacto desde tu portafolio para platicar sobre un proyecto.`;
      window.open(`https://wa.me/527223680858?text=${encodeURIComponent(text)}`, '_blank');
    });
  </script>
</section>
