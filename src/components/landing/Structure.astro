  <script>
    // Lógica de WhatsApp
    const whatsappBtn = document.getElementById('send-whatsapp-quick') as HTMLButtonElement | null;
    whatsappBtn?.addEventListener('click', () => {
      const name = (document.getElementById('contact-name-quick') as HTMLInputElement | null)?.value.trim();
      if (!name) { alert('Por favor escribe tu nombre.'); return; }
      const text = `Hola Antonio, soy ${name}. Te contacto desde tu portafolio para platicar sobre un proyecto.`;
      window.open(`https://wa.me/527223680858?text=${encodeURIComponent(text)}`, '_blank');
    });

    // Lógica de Rotación de Citas (Active Viewing)
    const quotes = [
        "\"El código es poesía en movimiento.\"",
        "\"La simplicidad es la máxima sofisticación.\" — Leonardo da Vinci",
        "\"No me importa si funciona en tu máquina, ¡no estamos vendiendo tu máquina!\"",
        "\"Primero resuelve el problema. Entonces, escribe el código.\" — John Johnson",
        "\"La función de un buen software es hacer que lo complejo parezca simple.\"",
        "\"Hazlo simple, hazlo memorable.\"",
        "\"El mejor código es el que no existe.\"",
        "\"First, solve the problem. Then, write the code.\"",
        "\"Any fool can write code a computer understands. Good programmers write code humans understand.\" — M. Fowler",
        "\"Make it work, make it right, make it fast.\" — Kent Beck",
        "\"Code is like humor. When you have to explain it, it's bad.\" — Cory House",
        "\"Clean code always looks like it was written by someone who cares.\"",
        "\"The best error message is the one that never shows up.\""
    ];

    const quoteElement = document.getElementById('bento-quote');
    let lastIndex = 0;

    function changeQuote() {
        if (!quoteElement) return;
        quoteElement.style.opacity = "0";

        setTimeout(() => {
            let randomIndex;
            do {
                randomIndex = Math.floor(Math.random() * quotes.length);
            } while (randomIndex === lastIndex);
            
            lastIndex = randomIndex;
            quoteElement.textContent = quotes[randomIndex];
            quoteElement.style.opacity = "1";
        }, 500);
    }

    if (quoteElement) {
      setInterval(changeQuote, 6000);
    }

    // ── Bento Card Entrance Animations (IntersectionObserver) ──
    const bentoCards = document.querySelectorAll('.bento-grid-root > div');
    bentoCards.forEach((card, i) => {
      (card as HTMLElement).style.setProperty('--delay', `${i * 75}ms`);
      card.classList.add('bento-card');
    });

    const bentoObserver = new IntersectionObserver((entries) => {
      entries.forEach(entry => {
        if (entry.isIntersecting) {
          entry.target.classList.add('bento-visible');
          bentoObserver.unobserve(entry.target);
        }
      });
    }, { threshold: 0.05 });

    document.querySelectorAll('.bento-card').forEach(el => bentoObserver.observe(el));
  </script>

  <style>
    @keyframes shimmer {
      0% { transform: translateX(-100%); }
      100% { transform: translateX(100%); }
    }

    .animate-shimmer::after {
      content: '';
      position: absolute;
      top: 0;
      left: 0;
      width: 100%;
      height: 100%;
      background: linear-gradient(
        90deg,
        transparent,
        rgba(255, 255, 255, 0.4),
        transparent
      );
      animation: shimmer 2.5s infinite;
    }

    /* Bento card entrance animation */
    .bento-card {
      opacity: 0;
      transform: translateY(18px);
      transition:
        opacity  0.55s ease var(--delay, 0ms),
        transform 0.55s ease var(--delay, 0ms);
    }
    .bento-card.bento-visible {
      opacity: 1;
      transform: translateY(0);
    }
  </style>
